<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE form-validation PUBLIC
  "-//Apache Software Foundation//DTD Commons Validator Rules Configuration 1.3.0//EN"
  "http://jakarta.apache.org/commons/dtds/validator_1_3_0.dtd">
<form-validation>
    <formset>
        <!-- Equipment Master -->
        <form name="eqpForm">
            <field property="equipmentName" depends="required">
                <arg key="label.equipmentName"/>
            </field>
            <field property="equipmentType" depends="required">
                <arg key="label.equipmentType"/>
            </field>
            <field property="status" depends="required">
                <arg key="label.status"/>
            </field>
            <field property="maintenanceRank" depends="required">
                <arg key="label.maintenanceRank"/>
            </field>
            <field property="inspectionInterval" depends="intRange">
                <arg key="label.inspectionInterval"/>
                <arg name="intRange" key="${var:min}" resource="false"/>
                <arg name="intRange" key="${var:max}" resource="false"/>
                <var><var-name>min</var-name><var-value>1</var-value></var>
                <var><var-name>max</var-name><var-value>120</var-value></var>
            </field>
        </form>

        <!-- Check Item Template -->
        <form name="chkItemForm">
            <field property="templateName" depends="required">
                <arg key="label.templateName"/>
            </field>
            <field property="equipmentType" depends="required">
                <arg key="label.equipmentType"/>
            </field>
            <field property="inspectionKind" depends="required">
                <arg key="label.inspectionKind"/>
            </field>
        </form>

        <!-- Incident -->
        <form name="incidentForm">
            <field property="incidentType" depends="required">
                <arg key="label.incidentType"/>
            </field>
            <field property="severity" depends="required">
                <arg key="label.severity"/>
            </field>
            <field property="incidentPart" depends="required">
                <arg key="label.incidentPart"/>
            </field>
            <field property="incidentDetail" depends="required,maxlength">
                <arg key="label.incidentDetail"/>
                <arg name="maxlength" key="${var:maxlength}" resource="false"/>
                <var><var-name>maxlength</var-name><var-value>2000</var-value></var>
            </field>
        </form>

        <!-- Employee -->
        <form name="empForm">
            <field property="name" depends="required">
                <arg key="label.empName"/>
            </field>
            <field property="nameKana" depends="mask">
                <arg key="label.nameKana"/>
                <var><var-name>mask</var-name><var-value>^[ァ-ヴー\s]+$</var-value></var>
            </field>
            <field property="loginId" depends="required">
                <arg key="label.loginId"/>
            </field>
            <field property="password" depends="minlength">
                <arg key="label.password"/>
                <arg name="minlength" key="${var:minlength}" resource="false"/>
                <var><var-name>minlength</var-name><var-value>8</var-value></var>
            </field>
        </form>

        <!-- CAPA -->
        <form name="capaForm">
            <field property="why1" depends="required"><arg key="label.why1"/></field>
            <field property="why2" depends="required"><arg key="label.why2"/></field>
            <field property="why3" depends="required"><arg key="label.why3"/></field>
            <field property="why4" depends="required"><arg key="label.why4"/></field>
            <field property="why5" depends="required"><arg key="label.why5"/></field>
            <field property="countermeasure" depends="required"><arg key="label.countermeasure"/></field>
            <field property="verifyMethod" depends="required"><arg key="label.verifyMethod"/></field>
            <field property="verifyDate" depends="required"><arg key="label.verifyDate"/></field>
        </form>

        <!-- Department -->
        <form name="deptForm">
            <field property="deptName" depends="required"><arg key="label.deptName"/></field>
            <field property="deptType" depends="required"><arg key="label.deptType"/></field>
            <field property="startDate" depends="required"><arg key="label.startDate"/></field>
        </form>

        <!-- Calendar -->
        <form name="calendarRegForm">
            <field property="dateFrom" depends="required"><arg key="label.dateFrom"/></field>
            <field property="dateTo" depends="required"><arg key="label.dateTo"/></field>
            <field property="holidayType" depends="required"><arg key="label.holidayType"/></field>
        </form>

        <!-- Parts -->
        <form name="partsForm">
            <field property="partName" depends="required"><arg key="label.partName"/></field>
        </form>

        <!-- Plan Wizard -->
        <form name="planWizardForm">
            <field property="planDate" depends="required"><arg key="label.planDate"/></field>
        </form>
    </formset>
</form-validation>
