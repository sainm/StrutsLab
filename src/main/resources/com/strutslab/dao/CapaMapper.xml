<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.strutslab.dao.CapaDao">

    <resultMap id="capaMap" type="com.strutslab.dto.CapaDto">
        <id property="capaId" column="capa_id"/>
        <result property="incidentNo" column="incident_no"/>
        <result property="why1" column="why1"/>
        <result property="why2" column="why2"/>
        <result property="why3" column="why3"/>
        <result property="why4" column="why4"/>
        <result property="why5" column="why5"/>
        <result property="countermeasure" column="countermeasure"/>
        <result property="verifyMethod" column="verify_method"/>
        <result property="verifyDate" column="verify_deadline"/>
        <result property="status" column="status"/>
    </resultMap>

    <!-- Insert CAPA -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="capaId" keyColumn="capa_id">
        INSERT INTO capa_reports (
            incident_no, why1, why2, why3, why4, why5,
            countermeasure, verify_method, verify_deadline, status
        ) VALUES (
            #{incidentNo}, #{why1}, #{why2}, #{why3}, #{why4}, #{why5},
            #{countermeasure}, #{verifyMethod}, #{verifyDate}, #{status}
        )
    </insert>

    <!-- Find by ID -->
    <select id="findById" resultMap="capaMap">
        SELECT * FROM capa_reports WHERE capa_id = #{capaId}
    </select>

    <!-- Find by incident no -->
    <select id="findByIncidentNo" resultMap="capaMap">
        SELECT * FROM capa_reports WHERE incident_no = #{incidentNo}
        ORDER BY capa_id DESC LIMIT 1
    </select>

</mapper>
